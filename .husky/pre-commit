# Auto-bump bridge version when bridge source files change
BRIDGE_FILES=$(git diff --cached --name-only -- 'bridge/' | grep -v '^bridge/package\.json$' | grep -v '^bridge/package-lock\.json$')

if [ -n "$BRIDGE_FILES" ]; then
  cd bridge && npm version patch --no-git-tag-version && npm install && cd ..
  git add bridge/package.json bridge/package-lock.json
fi
